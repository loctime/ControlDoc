{
  "name": "controldoc",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "npm run clean-ports && npm run fix-emotion && concurrently --kill-others --prefix-colors \"cyan,magenta\" --names \"FRONTEND,BACKEND\" \"vite\" \"npm run dev --prefix backend\"",
    "clean-ports": "node scripts/cleanup-ports.js",
    "fix-emotion": "node scripts/fix-emotion-aggressive.js && node scripts/force-browser-refresh.js",
    "predev": "node scripts/copyPdfWorker.js",
    "dev:all": "concurrently --kill-others --prefix-colors \"cyan,magenta\" --names \"FRONTEND,BACKEND\" \"vite\" \"npm run dev --prefix backend\"",
    "prebuild": "node scripts/copyPdfWorker.js",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "vercel-build": "node vercel-build.cjs",
    "reinstall": "powershell -Command \"Remove-Item -Recurse -Force node_modules -ErrorAction SilentlyContinue; Remove-Item -Force package-lock.json -ErrorAction SilentlyContinue; npm install\"",
    "build:vercel": "vite build --config vite.config.vercel.js",
    "fix-assets": "node scripts/fix-asset-loading.cjs",
    "verify-config": "node scripts/verify-vite-config.cjs"
  },
  "dependencies": {
    "@emotion/cache": "^11.11.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.6",
    "@mui/material": "^5.15.6",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "axios": "^1.9.0",
    "date-fns": "^3.6.0",
    "driver.js": "^1.3.6",
    "file-saver": "^2.0.5",
    "firebase": "^11.8.1",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "notistack": "^3.0.2",
    "papaparse": "^5.5.2",
    "pdfjs-dist": "^5.3.31",
    "react": "^18.3.1",
    "react-date-range": "^2.0.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.6.0",
    "stylis": "^4.3.6",
    "stylis-plugin-rtl": "^2.1.1",
    "sweetalert2": "^11.21.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@emotion/babel-plugin": "^11.13.5",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "puppeteer": "^24.17.0",
    "vite": "^4.5.2",
    "vite-plugin-remove-console": "^2.2.0"
  }
}
